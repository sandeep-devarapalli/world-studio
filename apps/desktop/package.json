{
  "name": "@world-studio/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "setup": "node scripts/ensure-electron.mjs",
    "dev": "pnpm run setup && tsc -p tsconfig.json && WORLD_STUDIO_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "package": "node scripts/package-macos.mjs",
    "smoke": "node scripts/smoke-packaged.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@world-studio/artifacts": "workspace:*",
    "@world-studio/world-core": "workspace:*",
    "electron": "43.1.1"
  },
  "devDependencies": {
    "typescript": "7.0.2"
  }
}

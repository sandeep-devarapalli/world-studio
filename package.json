{
  "name": "world-studio",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm --filter @world-studio/web dev",
    "desktop:setup": "pnpm --filter @world-studio/desktop run setup",
    "desktop:dev": "concurrently -k -s first -n web,desktop \"pnpm --filter @world-studio/web dev --host 127.0.0.1\" \"node scripts/wait-for-url.mjs http://127.0.0.1:5173 && pnpm --filter @world-studio/desktop dev\"",
    "desktop:package": "pnpm build && pnpm --filter @world-studio/desktop run package",
    "desktop:smoke": "pnpm --filter @world-studio/desktop run smoke",
    "desktop:package:smoke": "pnpm desktop:package && pnpm desktop:smoke",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:ui": "playwright test",
    "clone:upstreams": "node scripts/clone-upstreams.mjs",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm typecheck"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
